{%- extends 'lab/index.html.j2' -%}

{% block extra_css %}
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500&family=Roboto+Mono:wght@400;500&family=Zen+Kaku+Gothic+New:wght@400;500&display=swap" rel="stylesheet">
<style type="text/css">
:root{
  --cc-ink:#202124;--cc-mut:#5f6368;--cc-bd:#e0e0e0;--cc-codebg:#f7f7f7;--cc-blue:#1a73e8;
  --cc-ui:'Roboto',-apple-system,'Zen Kaku Gothic New',sans-serif;--cc-mono:'Roboto Mono',monospace;
}
body.jp-Notebook{background:#fff;}
main{max-width:960px;margin:0 auto;padding:24px 20px 70px;}

/* ---------- generic cell (Colab-style row) ---------- */
.cc-cell{margin:14px 0;font-family:var(--cc-ui);}
.cc-runbtn{width:24px;height:24px;border-radius:50%;border:1px solid var(--cc-bd);background:#fff;
  display:inline-flex;align-items:center;justify-content:center;color:var(--cc-mut);flex:0 0 auto;}
.cc-runbtn svg{margin-left:2px;}
.cc-body{min-width:0;}

/* ---------- collapsible code ---------- */
details.cc-code{border:1px solid var(--cc-bd);border-radius:8px;background:var(--cc-codebg);overflow:hidden;margin-top:8px;}
details.cc-code>summary{list-style:none;cursor:pointer;display:flex;align-items:center;gap:8px;
  padding:7px 12px;color:var(--cc-mut);font-size:12.5px;background:#fff;border-bottom:1px solid var(--cc-bd);}
details.cc-code>summary::-webkit-details-marker{display:none;}
details.cc-code:not([open])>summary{border-bottom:0;}
.cc-ico{transition:transform .15s;}
details.cc-code[open] .cc-ico{transform:rotate(90deg);}
.cc-lbl-show{display:inline;} .cc-lbl-hide{display:none;}
details.cc-code[open] .cc-lbl-show{display:none;} details.cc-code[open] .cc-lbl-hide{display:inline;}
details.cc-code .jp-InputArea-editor{border:0;background:transparent;}
details.cc-code .jp-InputArea{overflow:visible;}

/* ---------- Colab "form" cell ---------- */
.cc-title{font-family:var(--cc-ui);font-weight:500;font-size:15px;color:var(--cc-ink);margin:18px 0 6px;}
.cc-form{border:1px solid var(--cc-bd);border-radius:8px;background:#fff;overflow:hidden;}
.cc-form-row{display:flex;align-items:flex-start;gap:10px;padding:12px 14px;}
.cc-form-row>.cc-runbtn{margin-top:1px;}
.cc-form-content{flex:1;min-width:0;}
.cc-form-md{padding:0;color:var(--cc-ink);font-size:13px;line-height:1.7;}
.cc-form-md table{border-collapse:collapse;margin:6px 0;}
.cc-form-md th,.cc-form-md td{border:1px solid var(--cc-bd);padding:4px 10px;text-align:left;}
.cc-form-md hr{border:0;border-top:1px solid var(--cc-bd);margin:8px 0;}
.cc-form-grid{padding:10px 0 2px;display:grid;grid-template-columns:220px 1fr;gap:12px 18px;align-items:center;}
.cc-form-grid>label{color:var(--cc-mut);font-family:var(--cc-mono);font-size:13px;}
.cc-fld{display:flex;align-items:center;gap:10px;}
.cc-fld input[type=text]{font-family:var(--cc-mono);font-size:13px;padding:7px 10px;border:1px solid var(--cc-bd);
  border-radius:4px;width:280px;color:var(--cc-ink);background:#fff;}
.cc-fld select{font-size:13px;padding:7px 10px;border:1px solid var(--cc-bd);border-radius:4px;background:#fff;min-width:200px;color:var(--cc-ink);}
.cc-fld input[type=range]{width:240px;accent-color:var(--cc-blue);}
.cc-fld input[type=checkbox]{width:18px;height:18px;accent-color:var(--cc-blue);}
.cc-fld .cc-val{font-family:var(--cc-mono);color:var(--cc-ink);min-width:28px;}

/* ---------- outputs: align to the cell body & let wide content scroll ---------- */
/* Jupyter's In/Out prompt columns shift outputs (and code) right of the form/code
   box; hide them so everything shares the same left edge and width. */
.jp-InputPrompt,.jp-OutputPrompt,.jp-OutputArea-prompt{display:none!important;}
.cc-body .jp-Cell-outputWrapper{margin:8px 0 0;}
.cc-body .jp-OutputArea,.cc-body .jp-OutputArea-child{padding:0;margin:0;width:100%;}
/* Wide outputs (e.g. a 3Dmol grid wider than the column) scroll instead of being
   clipped on the right. */
.cc-body .jp-OutputArea-output{padding:0;margin:0;max-width:100%;overflow-x:auto;}
.cc-body .jp-OutputArea .jp-RenderedHTMLCommon{padding:0;}
.cc-body .jp-RenderedImage img,.cc-body .jp-OutputArea img{max-width:100%;height:auto;}
</style>
{% endblock extra_css %}

{%- macro cc_runbtn() -%}
<span class="cc-runbtn"><svg width="11" height="11" viewBox="0 0 12 12" fill="currentColor"><path d="M2 1.5v9l8-4.5z"/></svg></span>
{%- endmacro -%}

{%- macro cc_summary() -%}
<summary><span class="cc-ico">&#9656;</span><span class="cc-lbl-show">Show code</span><span class="cc-lbl-hide">Hide code</span></summary>
{%- endmacro -%}

{# chardin guided-tour attributes for one target (form/code/output), if specified #}
{%- macro ch_attr(ch, target) -%}
{%- set c = ch.get(target) -%}
{%- if c %} data-intro="{{ c.text }}" data-position="{{ c.position }}"{% endif -%}
{%- endmacro -%}

{% block footer_js %}
<script>
/* Mirror each slider's value into its adjacent label (look only, no compute). */
document.querySelectorAll('.cc-fld input[type=range]').forEach(function(r){
  var v = r.nextElementSibling;
  if (v) r.addEventListener('input', function(){ v.textContent = r.value; });
});
</script>
{% endblock footer_js %}

{% block codecell %}
{%- set form = cell.metadata.get('colab_form', {}) -%}
{%- set ch = form.get('chardin', {}) -%}
{%- set is_form = form.get('title') or form.get('fields') or form.get('markdown') -%}
<div class="cc-cell jp-Cell jp-CodeCell jp-Notebook-cell {{ celltags(cell) }}"{{ ch_attr(ch, 'cell') }}>
{%- if is_form and form.get('title') -%}
<div class="cc-title">{{ form.title }}</div>
{%- endif -%}
<div class="cc-body">
{%- if is_form -%}
  <div class="cc-form"{{ ch_attr(ch, 'form') }}>
    <div class="cc-form-row">
    {{ cc_runbtn() }}
    <div class="cc-form-content">
    {%- if form.get('markdown') -%}
    <div class="cc-form-md jp-RenderedHTMLCommon">{{ form.markdown | markdown2html }}</div>
    {%- endif -%}
    {%- if form.get('fields') -%}
    <div class="cc-form-grid">
      {%- for f in form.fields -%}
      <label>{{ f.name }}</label>
      <div class="cc-fld">
        {%- if f.kind == 'boolean' -%}
          <input type="checkbox" {% if f.checked %}checked{% endif %}>
        {%- elif f.kind == 'enum' -%}
          <select>{% for o in f.options %}<option {% if o == f.value %}selected{% endif %}>{{ o }}</option>{% endfor %}</select>
        {%- elif f.kind == 'slider' -%}
          <input type="range" min="{{ f.min }}" max="{{ f.max }}" step="{{ f.step }}" value="{{ f.value }}"><span class="cc-val">{{ f.value }}</span>
        {%- else -%}
          <input type="text" value="{{ f.value }}">
        {%- endif -%}
      </div>
      {%- endfor -%}
    </div>
    {%- endif -%}
    </div>
    </div>
  </div>
  <details class="cc-code"{{ ch_attr(ch, 'code') }}>{{ cc_summary() }}{{ self.input() }}</details>
{%- else -%}
  <details class="cc-code" open{{ ch_attr(ch, 'code') }}>{{ cc_summary() }}{{ self.input() }}</details>
{%- endif -%}
{%- if cell.outputs -%}<div class="cc-output"{{ ch_attr(ch, 'output') }}>{{ self.output_group() }}</div>{%- endif -%}
</div>
</div>
{% endblock codecell %}
